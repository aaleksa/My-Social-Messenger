{
  "name": "social-network-messenger",
  "version": "1.0.0",
  "description": "Social Network Desktop Messenger",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev:renderer": "cd renderer && npm run dev",
    "dev": "concurrently -k -n renderer,electron -c cyan,yellow \"npm run dev:renderer\" \"wait-on http://localhost:5173 && ELECTRON_DEV=true electron .\"",
    "build:renderer": "cd renderer && npm run build",
    "build:win": "npm run build:renderer && electron-builder --win",
    "build:mac": "npm run build:renderer && electron-builder --mac",
    "build:linux": "npm run build:renderer && electron-builder --linux"
  },
  "build": {
    "appId": "com.socialnetwork.messenger",
    "productName": "Social Messenger",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0",
    "wait-on": "^7.2.0"
  }
}
